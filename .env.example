# --- LLM provider (claim extraction + verdict generation) ---
LLM_PROVIDER=openai          # "openai" | "anthropic"
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Embeddings for the curated corpus (uses the OpenAI key above)
EMBEDDING_MODEL=text-embedding-3-small

# --- Web search (optional; backend degrades to corpus-only retrieval if unset) ---
SEARCH_PROVIDER=tavily       # "tavily" | "brave" | "none"
TAVILY_API_KEY=
BRAVE_API_KEY=

# --- Retrieval / corpus ---
CHROMA_PERSIST_DIR=./chroma_data
CORPUS_COLLECTION_NAME=pravda_corpus
CORPUS_TOP_K=5

# --- Ranking ---
RELIABILITY_RECENCY_HALFLIFE_DAYS=365

# --- CORS (comma-separated list is not supported by pydantic-settings list parsing here;
# edit backend/app/config.py directly if you need more than "*") ---
CORS_ORIGINS=["*"]
