{
  "manifest_version": 3,
  "name": "Pravda — Catch Lies",
  "version": "0.1.0",
  "description": "Highlight any claim on a webpage and get an instant, sourced evidence-quality verdict.",
  "permissions": ["activeTab", "scripting", "sidePanel", "storage", "contextMenus"],
  "host_permissions": ["http://localhost:8000/*", "http://127.0.0.1:8000/*"],
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content-script.js"],
      "css": ["sidepanel/content.css"]
    }
  ],
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "action": {
    "default_title": "Open Pravda"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
